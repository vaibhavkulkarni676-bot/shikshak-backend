# ============================================
# SHIKSHAK.AI BACKEND — ENVIRONMENT VARIABLES
# ============================================
# Copy this file to ".env" (remove ".example") and fill in the values below.
# Never commit your real .env file to GitHub.

# ---- AI Providers ----
# You need AT LEAST ONE of these two. Both can be set — the frontend lets
# you pick which one to use per request.

# 1) Anthropic (Claude) — get a key at https://console.anthropic.com
#    Console -> Settings -> API Keys -> Create Key
#    Note: you must add a payment method under Billing before it will work.
ANTHROPIC_API_KEY=

# 2) Google Gemini — get a free key at https://aistudio.google.com/apikey
#    Click "Create API key" — Gemini has a genuinely free tier, no card needed
#    to get started (rate-limited).
GEMINI_API_KEY=

# ---- Security ----
# A random secret used to sign login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If you leave this blank, the server will auto-generate one on each restart
# (fine for local testing, but everyone gets logged out every restart).
JWT_SECRET=

# ---- Server ----
PORT=3000

# Comma-separated list of frontend URLs allowed to call this backend.
# Use * only for local testing — lock this down before going live.
FRONTEND_ORIGINS=*

# Max API calls allowed per IP per hour (basic abuse protection)
RATE_LIMIT_PER_HOUR=60
